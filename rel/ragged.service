[Unit]
Description=Ragged
After=network.target

[Service]
Type=simple
User=aleak
Group=aleak
WorkingDirectory=/home/aleak
ExecStart=/bin/bash --login -c 'source /home/aleak/.bashrc; cd /home/aleak; /home/aleak/src/ragged/_build/prod/rel/ragged/bin/ragged foreground'
Restart=on-failure
RestartSec=5
Environment=PORT=5070
Environment=LANG=en_US.UTF-8
SyslogIdentifier=ragged
RemainAfterExit=no

[Install]
WantedBy=multi-user.target

